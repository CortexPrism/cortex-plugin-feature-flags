{
  "name": "cortex-plugin-feature-flags",
  "version": "1.0.1",
  "description": "Feature Flag Lifecycle Manager \u2014 LaunchDarkly/Flagsmith/Unleash for flag creation, targeting, monitoring, cleanup",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-feature-flags",
  "homepage": "https://cortexprism.io/marketplace/plugins/feature-flags",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
  "tools": [
    {
      "name": "flag_create",
